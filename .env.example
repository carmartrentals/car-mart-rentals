# ============================================================
# Car Mart Rentals — Environment Variables
# Copy this file to .env.local and fill in real values.
# ============================================================

# --- Supabase ---------------------------------------------------------------
# Found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Stripe (Phase 2) -------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Email (Phase 3) --------------------------------------------------------
# Provider-agnostic; wire to Resend / SendGrid / SES later.
EMAIL_FROM=reservations@carmartrentals.com
RESEND_API_KEY=

# --- Admin API (mobile app / future) ---------------------------------------
# Shared secret for server-to-server API auth.
API_BEARER_SECRET=change-me-to-a-long-random-string
